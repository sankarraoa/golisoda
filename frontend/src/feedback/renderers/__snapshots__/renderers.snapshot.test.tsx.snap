// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderer snapshots (byte-stable DOM) > csat_5 emoji_5 1`] = `"<div class="emoji-scale emoji-scale--csat" role="group" aria-labelledby="q-q"><div class="emoji-scale-row"><button class="emoji-scale-button " type="button"><span aria-hidden="true" class="emoji-scale-glyph">😡</span><span class="emoji-scale-caption">Very Poor</span></button><button class="emoji-scale-button " type="button"><span aria-hidden="true" class="emoji-scale-glyph">😞</span><span class="emoji-scale-caption">Poor</span></button><button class="emoji-scale-button emoji-scale-button--selected" type="button"><span aria-hidden="true" class="emoji-scale-glyph">😐</span><span class="emoji-scale-caption">Fair</span></button><button class="emoji-scale-button " type="button"><span aria-hidden="true" class="emoji-scale-glyph">😊</span><span class="emoji-scale-caption">Good</span></button><button class="emoji-scale-button " type="button"><span aria-hidden="true" class="emoji-scale-glyph">😍</span><span class="emoji-scale-caption">Excellent</span></button></div></div>"`;

exports[`renderer snapshots (byte-stable DOM) > dropdown 1`] = `"<div class="field"><label class="field-label" for="q">Select one</label><select class="field-input" id="q"><option value="">Choose an option</option><option value="a">A</option><option value="b">B</option></select></div>"`;

exports[`renderer snapshots (byte-stable DOM) > nps numeric 1`] = `"<div class="nps-scale nps-scale--heatmap"><div class="nps-options nps-options--heatmap" role="radiogroup" aria-label="Likelihood score 0–10"><button aria-checked="false" class="nps-heatmap-cell nps-heatmap-cell--s0 " role="radio" type="button"><span class="nps-heatmap-cell-label">0</span></button><button aria-checked="false" class="nps-heatmap-cell nps-heatmap-cell--s1 " role="radio" type="button"><span class="nps-heatmap-cell-label">1</span></button><button aria-checked="false" class="nps-heatmap-cell nps-heatmap-cell--s2 " role="radio" type="button"><span class="nps-heatmap-cell-label">2</span></button><button aria-checked="false" class="nps-heatmap-cell nps-heatmap-cell--s3 " role="radio" type="button"><span class="nps-heatmap-cell-label">3</span></button><button aria-checked="false" class="nps-heatmap-cell nps-heatmap-cell--s4 " role="radio" type="button"><span class="nps-heatmap-cell-label">4</span></button><button aria-checked="false" class="nps-heatmap-cell nps-heatmap-cell--s5 " role="radio" type="button"><span class="nps-heatmap-cell-label">5</span></button><button aria-checked="false" class="nps-heatmap-cell nps-heatmap-cell--s6 " role="radio" type="button"><span class="nps-heatmap-cell-label">6</span></button><button aria-checked="false" class="nps-heatmap-cell nps-heatmap-cell--s7 " role="radio" type="button"><span class="nps-heatmap-cell-label">7</span></button><button aria-checked="false" class="nps-heatmap-cell nps-heatmap-cell--s8 " role="radio" type="button"><span class="nps-heatmap-cell-label">8</span></button><button aria-checked="true" class="nps-heatmap-cell nps-heatmap-cell--s9 nps-heatmap-cell--selected" role="radio" type="button"><span class="nps-heatmap-cell-label">9</span></button><button aria-checked="false" class="nps-heatmap-cell nps-heatmap-cell--s10 " role="radio" type="button"><span class="nps-heatmap-cell-label">10</span></button></div><div class="scale-labels scale-labels--heatmap-nps"><span>Not at all likely</span><span>Extremely likely</span></div></div>"`;

exports[`renderer snapshots (byte-stable DOM) > plain_text 1`] = `"<div class="field"><label class="field-label" for="q">Your answer</label><textarea class="field-input field-textarea" id="q" placeholder="Type your response">hello</textarea></div>"`;
