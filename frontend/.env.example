VITE_API_BASE_URL=http://localhost:8000

# Optional: only if the survey-template list is on another origin (split deploy, tenant-admin
# without `/survey-templates`). Defaults to VITE_API_BASE_URL.
# VITE_TEMPLATE_API_BASE_URL=http://localhost:8002

# Optional: only if `/f/*` is served by the Public Feedback app (e.g. :8001) instead of
# tenant-admin. Defaults to VITE_API_BASE_URL.
# VITE_PUBLIC_FEEDBACK_API_URL=http://localhost:8001

# Platform super-admin API (e.g. uvicorn app.main_platform_admin:app --port 8003)
VITE_PLATFORM_API_BASE_URL=http://localhost:8003
