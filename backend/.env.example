APP_NAME="Goli Soda Feedback API"
ENVIRONMENT=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://goli_soda:goli_soda_dev_password@localhost:5432/goli_soda
REDIS_URL=redis://localhost:6379/0

JWT_ISSUER=goli-soda
JWT_AUDIENCE=goli-soda-api
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-local-only-please-override

# Generate with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
PII_MASTER_KEY=change-me-in-local-only

PUBLIC_FEEDBACK_BASE_URL=http://127.0.0.1:5173
ADMIN_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
