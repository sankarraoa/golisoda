{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.12"
  },
  "steps": {
    "install": {
      "commands": [
        "...",
        "pip install --upgrade pip",
        "pip install ."
      ]
    }
  },
  "deploy": {
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
